<% layout('layouts/boilerplate') %>
    <h1>Zaloguj</h1>
    <form action="/login" method="POST" class="validateForm" novalidate>
        <div class="mb-3"><label class="form-label" for="username">Nazwa</label>
            <input class="form-control" type="text" id="username" name="username" required>
            <div class="valid-feedback">
                👍
            </div>
        </div>

        <div class="mb-3"><label class="form-label" for="password">Hasło</label>
            <input class="form-control" type="password" id="password" name="password" required>
            <div class="valid-feedback">
                👍
            </div>
        </div>

        <button class="btn btn-success">Zaloguj</button>

    </form>