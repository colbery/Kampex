<% layout('layouts/boilerplate.ejs') %>
    <H1 class="offset-3">Kampex</H1>
    <div class="offset-3"><a href="/kampex/new">Dodaj Kampex</a></div>

    <% for (let kamp of kampa) {%>
        <div class="card mb-3 offset-3">
            <div class="row">
                <div class="col-md-4">
                    <img class="img-fluid" src="<%=kamp.image%>">
                </div>
                <div class="col-md-8">
                    <div class="car-body">
                        <h5 class="card-title">
                            <%=kamp.title%>
                        </h5>
                        <p class="card-text">
                            <%=kamp.description%>
                        </p>
                        <p class="card-text">
                            <small class="text-muted">
                                <%=kamp.location%>
                            </small>
                        </p>
                        <a class="btn btn-primary" href="/kampex/<%=kamp._id%>">Zobacz <%=kamp.title%></a>

                    </div>
                </div>
            </div>
        </div>
        <%}%>