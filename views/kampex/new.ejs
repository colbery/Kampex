<% layout('layouts/boilerplate.ejs') %>
    <div class="row">
        <h1 class="text-center">Nowy Kampex</h1>
        <div class="col-6 offset-3">

            <form action="/kampex" method="POST" novalidate class="validateForm">

                <div class="mb-3"><label class="form-label" for="title">Tytul</label>
                    <input class="form-control" type="text" id="title" name="kampex[title]" required>
                    <div class="valid-feedback">
                        👍
                    </div>
                </div>
                <div class="mb-3"><label class="form-label" for="location">Lokalizacja</label>
                    <input class="form-control" type="text" id="location" name="kampex[location]" required>
                    <div class="valid-feedback">
                        👍
                    </div>
                </div>
                <div class="mb-3"><label class="form-label" for="image">Zdjecie URL</label>
                    <input class="form-control" type="text" id="image" name="kampex[image]" required>
                    <div class="valid-feedback">
                        👍
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label" for="price">Cena Kampex</label>

                    <div class="input-group ">
                        <div class="input-group-prepend">
                            <span class="input-group-text" id="price-label">ZL</span>
                        </div>
                        <input type="text" class="form-control" id="price" placeholder="0.00" aria-label="price"
                            aria-describedby="price-label" name="kampex[price]" required>
                        <div class="valid-feedback">
                            👍
                        </div>
                    </div>
                </div>
                <div class="mb-3"><label class="form-label" for="description">Opis</label>
                    <textarea class="form-control" type="text" id="description" name="kampex[description]"
                        required></textarea>
                    <div class="valid-feedback">
                        👍
                    </div>
                </div>

                <div class="mb-3">
                    <button class="btn btn-success">Dodaj Kampex</button>

                </div>
            </form>
            <a href="/kampex">Powrot</a>
        </div>
    </div>